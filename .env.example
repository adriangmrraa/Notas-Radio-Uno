# ==========================================
# PeriodistApp - Variables de Entorno
# ==========================================

# --- DeepSeek AI (Primary - Text Generation & Analysis) ---
DEEPSEEK_API_KEY=

# --- Twitter ---
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# --- Google Drive (Image Hosting) ---
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_FOLDER_ID=

# --- Google Gemini (AI Fallback + Image Generation) ---
# Used as fallback for text generation if DeepSeek is unavailable
# Also used for Google Imagen (AI Image Generation)
GEMINI_API_KEY=

# --- xAI Grok Image (AI Image Generation - Optional) ---
XAI_API_KEY=

# --- Google Custom Search (Optional, fallback: DuckDuckGo) ---
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# --- Pipeline Webhook (Optional override) ---
WEBHOOK_URL_PIPELINE=

# ==========================================
# META (FACEBOOK + INSTAGRAM) - NUEVO
# ==========================================

# App ID de tu Meta App (developers.facebook.com)
META_APP_ID=

# App Secret de tu Meta App
META_APP_SECRET=

# (Opcional) Config ID para Facebook Login for Business
META_CONFIG_ID=

# Clave de encriptación para tokens en la DB (genera una clave aleatoria segura)
# Ejemplo: openssl rand -hex 32
ENCRYPTION_KEY=

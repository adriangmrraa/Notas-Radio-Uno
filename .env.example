# ================================================
# PERIODISTAPP - PRODUCTION ENVIRONMENT VARIABLES
# ================================================
#
# Copia este archivo como .env en tu VPS y rellena los valores.
# Para producciÃģn, NODE_ENV debe ser "production".
#
# ================================================
# 1. DATABASE (PostgreSQL) - REQUERIDO
# ================================================
# Formato: postgresql://usuario:contraseÃąa@host:puerto/nombre_bd
# Si PostgreSQL estÃĄ en el mismo VPS, usa localhost o 127.0.0.1
DATABASE_URL=postgresql://periodist:TU_CONTRASENA_SEGURA@localhost:5432/periodistapp

# ================================================
# 2. REDIS (Opcional pero recomendado para cache/sessions)
# ================================================
# Si instalÃĄs Redis en el mismo VPS, descomenta y configura:
# REDIS_URL=redis://:TU_CONTRASENA_REDIS@localhost:6379

# ================================================
# 3. AUTHENTICATION & SECURITY - REQUERIDOS
# ================================================
# Generar con: openssl rand -hex 32
JWT_SECRET=GENERA_UN_SECRETO_SEGURO_DE_32_BYTES_EN_HEX

# Clave para cifrar datos sensibles en DB (mismo comando)
ENCRYPTION_KEY=GENERA_OTRO_SECRETO_SEGURO_DE_32_BYTES_EN_HEX

# URL pÃšblica del frontend (sin / al final)
FRONTEND_URL=https://app.tudominio.com

# ================================================
# 4. SERVER CONFIGURATION
# ================================================
NODE_ENV=production
PORT=3001

# ================================================
# 5. AI PROVIDERS - mÃ­nimo uno requerido
# ================================================
# DeepSeek (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=sk-tu_key_deepseek

# Google Gemini (https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=AIzaSyTU_KEY_GEMINI

# xAI (Grok) - opcional
XAI_API_KEY=xai-tu_key_xai

# ================================================
# 6. TWITTER / X API - para publicar automÃĄticamente
# ================================================
# Crear app en https://developer.twitter.com/
TWITTER_APP_KEY=TU_CONSUMER_KEY
TWITTER_APP_SECRET=TU_CONSUMER_SECRET
TWITTER_ACCESS_TOKEN=TU_ACCESS_TOKEN
TWITTER_ACCESS_SECRET=TU_ACCESS_SECRET
TWITTER_CLIENT_ID=TU_CLIENT_ID  # Para OAuth2

# ================================================
# 7. GOOGLE APIs - para Google Drive y bÃšsqueda
# ================================================
# Service Account para Google Drive (crear en Google Cloud Console)
GOOGLE_CLIENT_EMAIL=tu-service-account@proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nTU_LLAVE_PRIVADA\n-----END PRIVATE KEY-----
GOOGLE_FOLDER_ID=ID_DE_CARPETA_DRIVE  # Donde se guardarÃĄn los archivos

# Google Custom Search (opcional - para bÃšsqueda de noticias)
GOOGLE_SEARCH_API_KEY=TU_KEY_GOOGLE_SEARCH
GOOGLE_SEARCH_CX=ID_DEL_MOTOR_DE_BUSQUEDA

# ================================================
# 8. META (Facebook + Instagram) - para publicar
# ================================================
# Crear app en https://developers.facebook.com/
META_APP_ID=TU_APP_ID
META_APP_SECRET=TU_APP_SECRET
META_CONFIG_ID=TU_CONFIG_ID  # ID de configuraciÃģn de publicaciÃģn

# ================================================
# 9. STRIPE - para pagos (si usÃĄs la funcionalidad de billing)
# ================================================
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_TU_KEY_SECRETA
STRIPE_WEBHOOK_SECRET=whsec_TU_WEBHOOK_SECRET

# ================================================
# 10. MERCADOPAGO - para pagos en Argentina (opcional)
# ================================================
MP_ACCESS_TOKEN=TU_ACCESS_TOKEN_MERCADOPAGO

# ================================================
# 11. EMAIL (SMTP) - para notificaciones y recuperaciÃģn de contraseÃąa
# ================================================
# ConfiguraciÃģn para Gmail o tu propio servidor SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true  # true para SSL, false para STARTTLS
SMTP_USER=noreply@tudominio.com
SMTP_PASS=TU_CONTRASENA_DE_APLICACION_GMAIL
SMTP_FROM="PeriodistApp <noreply@tudominio.com>"

# ================================================
# 12. WEBHOOKS - para integraciones externas
# ================================================
# URLs que recibirÃĄn notificaciones cuando se complete un pipeline
WEBHOOK_URL_PIPELINE=https://tudominio.com/webhook/pipeline
WEBHOOK_URL_NUEVO_BOTON=https://tudominio.com/webhook/nuevo-boton
WEBHOOK_URL_VIEJO_BOTON=https://tudominio.com/webhook/viejo-boton
WEBHOOK_URL_TERCER_BOTON=https://tudominio.com/webhook/tercer-boton

# ================================================
# 13. PLATFORM & BRANDING
# ================================================
# Nombre que aparecerÃĄ en placas, artÃ­culos y prompts de IA
PLATFORM_NAME=Radio Uno Formosa

# ================================================
# 14. TOOLS & PATHS
# ================================================
# Directorio donde se instalan herramientas como ffmpeg, whisper, yt-dlp
# En producciÃģn, generalmente estÃĄn en /usr/bin o /usr/local/bin
TOOLS_DIR=/usr/local/bin

# ================================================
# 15. APP SPECIFIC
# ================================================
# Variables internas del sistema (no modificar a menos que sepas)
# NODE_OPTIONS=--max-old-space-size=4096  # Para VPS con 4GB+ RAM

# ================================================
# 16. TRANSCRIPCION CON DIARIZACION
# ================================================
# AssemblyAI para diarizacion de hablantes (opcional  mejora atribucion de citas)
# Registro gratuito en https://www.assemblyai.com/
# Sin esta key, el sistema usa Whisper (sin distincion de hablantes)
ASSEMBLYAI_API_KEY=
